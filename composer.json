{
    "name": "mailcarrier/mailcarrier",
    "description": "Mailing platform with templates and logs included",
    "keywords": [
        "laravel",
        "mailcarrier"
    ],
    "homepage": "https://github.com/mailcarrierapp/mailcarrier",
    "license": "MIT",
    "authors": [
        {
            "name": "Danilo Polani",
            "email": "hello@mailcarrier.app",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "flowframe/laravel-trend": "^0.5",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "laravel/mcp": "^0.8.1",
        "laravel/passport": "^13.7",
        "laravel/prompts": "^0.3",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.6.1",
        "livewire/livewire": "^4.0",
        "nunomaduro/termwind": "^2.0",
        "pboivin/filament-peek": "^4.0",
        "ralphjsmit/laravel-filament-components": "^3.0",
        "socialiteproviders/manager": "^4.3",
        "spatie/laravel-package-tools": "^1.19",
        "twig/twig": "^3.5.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.7",
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-faker": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.2",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "MailCarrier\\": "src",
            "MailCarrier\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MailCarrier\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=-1",
        "test": "vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint -v"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MailCarrier\\MailCarrierServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
